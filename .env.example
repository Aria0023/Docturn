# DocTurn environment. Copy to .env. Both values below are OPTIONAL:
# with neither set, the app boots against an in-process PGlite database and a
# generated dev session secret — no external services required.

# Session signing secret. Set a long random value in production.
SESSION_SECRET=

# Postgres connection string. When unset, DocTurn uses in-process PGlite.
# DATABASE_URL=postgres://user:pass@localhost:5432/docturn

# --- Optional live integrations (each falls back to a local stub when absent) ---
# AI intake (gpt-4o); set USE_STUB_AI=true to force the deterministic mock.
# OPENAI_API_KEY=
# USE_STUB_AI=
# SMS / MFA carriers (selected per-org via notification_profile.smsCarrier).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# Push (FCM).
# FIREBASE_SERVICE_ACCOUNT_JSON=
# Scheduling (Amion).
# AMION_FACILITY_ID=
# AMION_API_KEY=
